@page "/metricas"
@rendermode RenderMode.InteractiveServer
@using MudBlazor
@using EscuelaManagement.Data.Models
@using EscuelaManagement.Data.Services
@using QuestPDF.Fluent
@inject FirebaseService Firebase
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <MudToolBar Class="px-0 mb-4 d-flex flex-wrap gap-3">
        <MudText Typo="Typo.h4" Color="Color.Primary">Panel de Ventas y Rendimiento</MudText>
        <MudSpacer />
        
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.PictureAsPdf" OnClick="DescargarReportePDF" Disabled="@generandoPdf">
            @if (generandoPdf)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                <span>GENERANDO...</span>
            }
            else
            {
                <span>EXPORTAR PDF</span>
            }
        </MudButton>

        @if (filtroTiempo == "Personalizado")
        {
            <MudDateRangePicker DateRange="rangoFechasCustom" 
                                DateRangeChanged="OnRangoFechasCambiado" 
                                Variant="Variant.Outlined" 
                                Margin="Margin.Dense" 
                                Style="max-width: 240px; background-color: white;" 
                                Clearable="true" 
                                PlaceholderStart="Fecha Inicio" 
                                PlaceholderEnd="Fecha Fin"
                                DisableToolbar="true" />
        }

        <MudSelect T="string" Value="@filtroTiempo" ValueChanged="OnFiltroCambiado" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 180px; background-color: white;">
            <MudSelectItem Value="@("Este Mes")">Este Mes</MudSelectItem>
            <MudSelectItem Value="@("Este Año")">Este Año</MudSelectItem>
            <MudSelectItem Value="@("Histórico")">Histórico (Todo)</MudSelectItem>
            <MudSelectItem Value="@("Personalizado")">Personalizado...</MudSelectItem>
        </MudSelect>

        <MudSelect T="string" Value="@filtroAsesor" ValueChanged="OnFiltroAsesorCambiado" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 220px; background-color: white;" Placeholder="Todos los Asesores">
            <MudSelectItem Value="@("Todos")">Todos los Asesores</MudSelectItem>
            @foreach(var asesor in listaAsesoresDisponibles)
            {
                <MudSelectItem Value="@asesor">@asesor</MudSelectItem>
            }
        </MudSelect>
    </MudToolBar>

    @if (cargando)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* --- SALUD FINANCIERA: PROYECTADO VS REAL --- *@
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="6">
            <MudPaper Elevation="3" Class="pa-4 border-l-4" Style="border-color: #2196f3; height: 100%;">
                <div class="d-flex justify-space-between align-start mb-2">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Default">Cobranza Efectiva (Dinero Real)</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Info"><b>@totalCobranzaReal.ToString("C")</b></MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Info" Size="Size.Large" />
                </div>
                <MudProgressLinear Color="Color.Info" Value="@porcentajeCobranza" Height="8px" Class="rounded-lg mb-1" />
                <MudText Typo="Typo.caption" Color="Color.Default"><b>@porcentajeCobranza.ToString("0.1")%</b> del ingreso proyectado ha sido cobrado.</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Elevation="3" Class="pa-4 border-l-4" Style="border-color: #f44336; height: 100%;">
                <div class="d-flex justify-space-between align-start">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Default">Pendiente por Cobrar / Cartera Vencida</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Error"><b>@carteraVencida.ToString("C")</b></MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" />
                </div>
                <MudText Typo="Typo.body2" Class="mt-3" Color="Color.Default">
                    Diferencia entre el valor de los contratos firmados en este periodo y los pagos efectivamente registrados en sistema.
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* --- 1. TARJETAS DE RESUMEN (KPIs) --- *@
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4 d-flex flex-column align-center justify-center border-t-4" Style="border-color: #4caf50; height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Success" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Default">Ingresos Proyectados</MudText>
                <MudText Typo="Typo.h5" Color="Color.Success"><b>@totalIngresos.ToString("C")</b></MudText>
                
                @if (mostrarCrecimiento)
                {
                    <div class="d-flex align-center mt-1">
                        <MudIcon Icon="@(crecimientoIngresos >= 0 ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown)" 
                                 Color="@(crecimientoIngresos >= 0 ? Color.Success : Color.Error)" Size="Size.Small" />
                        <MudText Typo="Typo.caption" Color="@(crecimientoIngresos >= 0 ? Color.Success : Color.Error)" Class="ml-1">
                            <b>@(crecimientoIngresos >= 0 ? "+" : "")@crecimientoIngresos.ToString("0.1")%</b> vs periodo ant.
                        </MudText>
                    </div>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4 d-flex flex-column align-center justify-center border-t-4" Style="border-color: #2196f3; height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Info" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Default">Total de Inscripciones</MudText>
                <MudText Typo="Typo.h5" Color="Color.Info"><b>@totalInscritos</b></MudText>

                @if (mostrarCrecimiento)
                {
                    <div class="d-flex align-center mt-1">
                        <MudIcon Icon="@(crecimientoInscritos >= 0 ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown)" 
                                 Color="@(crecimientoInscritos >= 0 ? Color.Success : Color.Error)" Size="Size.Small" />
                        <MudText Typo="Typo.caption" Color="@(crecimientoInscritos >= 0 ? Color.Success : Color.Error)" Class="ml-1">
                            <b>@(crecimientoInscritos >= 0 ? "+" : "")@crecimientoInscritos.ToString("0.1")%</b> vs periodo ant.
                        </MudText>
                    </div>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4 d-flex flex-column align-center justify-center border-t-4" Style="border-color: #ff9800; height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Default">Curso Estrella</MudText>
                <MudText Typo="Typo.h6" Align="Align.Center" Style="line-height: 1.2;"><b>@cursoEstrella</b></MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4 d-flex flex-column align-center justify-center border-t-4" Style="border-color: #9c27b0; height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Secondary" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Default">Mejor Asesor(a)</MudText>
                <MudText Typo="Typo.h6" Align="Align.Center"><b>@mejorAsesor</b></MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* --- 2. GRÁFICAS VISUALES --- *@
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3" Style="height: 100%;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Demanda por Curso</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="d-flex justify-center">
                    @if (dataCursos.Any())
                    {
                        <MudChart T="double" ChartType="ChartType.Pie" InputData="@dataCursos" InputLabels="@labelsCursos" Width="100%" Height="300px" />
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-10">No hay datos en este periodo.</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudCard Elevation="3" Style="height: 100%;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Ventas por Asesor</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (SeriesAsesores.Any() && SeriesAsesores.First().Data.Any())
                    {
                        <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@SeriesAsesores" XAxisLabels="@labelsAsesores" Width="100%" Height="300px" />
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-10 text-center">No hay ventas registradas en este periodo.</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* --- 3. TABLA DE DESGLOSE FINANCIERO --- *@
    <MudGrid Class="mt-4">
        <MudItem xs="12">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Desglose Financiero por Curso</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudTable Items="@desgloseCursos" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                        <HeaderContent>
                            <MudTh><b>Nombre del Curso</b></MudTh>
                            <MudTh Style="text-align:center;"><b>Inscripciones Vendidas</b></MudTh>
                            <MudTh Style="text-align:right;"><b>Ingresos Recabados</b></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Curso">@context.NombreCurso</MudTd>
                            <MudTd DataLabel="Inscripciones" Style="text-align:center;">
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.Cantidad</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Ingresos" Style="text-align:right; font-weight:500;">
                                @context.IngresoTotal.ToString("C")
                            </MudTd>
                        </RowTemplate>
                        <FooterContent>
                            <MudTd></MudTd>
                            <MudTd Style="text-align:center; font-size: 1.1rem;"><b>MONTO TOTAL PROYECTADO:</b></MudTd>
                            <MudTd Style="text-align:right; font-size: 1.1rem; color: #4caf50;">
                                <b>@totalIngresos.ToString("C")</b>
                            </MudTd>
                        </FooterContent>
                    </MudTable>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool cargando = true;
    private bool generandoPdf = false;
    
    private string filtroTiempo = "Este Mes";
    private string filtroAsesor = "Todos";
    private DateRange rangoFechasCustom = new DateRange(DateTime.Now.AddDays(-30).Date, DateTime.Now.Date);
    
    private ConfiguracionEscuela configuracion = new();
    private List<Enrollment> todasLasInscripciones = new();
    private List<Course> todosLosCursos = new();
    private List<Payment> todosLosPagos = new(); // Nueva lista global de pagos
    private List<string> listaAsesoresDisponibles = new();
    
    // Variables de KPIs Originales
    private double totalIngresos = 0;
    private int totalInscritos = 0;
    private string cursoEstrella = "N/A";
    private string mejorAsesor = "N/A";

    // Variables NUEVAS para Cobranza y Morosidad
    private double totalCobranzaReal = 0;
    private double porcentajeCobranza = 0;
    private double carteraVencida = 0;

    private bool mostrarCrecimiento = true;
    private double crecimientoIngresos = 0;
    private double crecimientoInscritos = 0;

    private double[] dataCursos = Array.Empty<double>();
    private string[] labelsCursos = Array.Empty<string>();

    private List<ChartSeries<double>> SeriesAsesores = new();
    private string[] labelsAsesores = Array.Empty<string>();

    private List<DesgloseCurso> desgloseCursos = new();

    public class DesgloseCurso
    {
        public string NombreCurso { get; set; } = "";
        public int Cantidad { get; set; }
        public double IngresoTotal { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        QuestPDF.Settings.License = QuestPDF.Infrastructure.LicenseType.Community;
        
        configuracion = await Firebase.GetConfiguracionAsync() ?? new();
        todasLasInscripciones = await Firebase.GetAllEnrollmentsAsync() ?? new();
        todosLosCursos = await Firebase.GetCoursesAsync() ?? new();
        todosLosPagos = await Firebase.GetAllPaymentsAsync() ?? new(); // Traemos todos los pagos de Firebase
        
        listaAsesoresDisponibles = todasLasInscripciones
            .Where(e => !string.IsNullOrWhiteSpace(e.AsesorAsignado))
            .Select(e => e.AsesorAsignado)
            .Distinct()
            .OrderBy(a => a)
            .ToList();

        ProcesarMetricas();
        cargando = false;
    }

    private void OnFiltroCambiado(string nuevoFiltro)
    {
        filtroTiempo = nuevoFiltro;
        ProcesarMetricas();
    }

    private void OnRangoFechasCambiado(DateRange nuevoRango)
    {
        rangoFechasCustom = nuevoRango;
        ProcesarMetricas();
    }

    private void OnFiltroAsesorCambiado(string nuevoAsesor)
    {
        filtroAsesor = nuevoAsesor;
        ProcesarMetricas();
    }

    private void ProcesarMetricas()
    {
        var fechaActual = DateTime.UtcNow;
        
        DateTime? currentStart = null;
        DateTime? currentEnd = null;
        DateTime? prevStart = null;
        DateTime? prevEnd = null;
        mostrarCrecimiento = true;

        if (filtroTiempo == "Este Mes")
        {
            currentStart = new DateTime(fechaActual.Year, fechaActual.Month, 1);
            currentEnd = currentStart.Value.AddMonths(1).AddTicks(-1);
            
            prevStart = currentStart.Value.AddMonths(-1);
            prevEnd = currentStart.Value.AddTicks(-1);
        }
        else if (filtroTiempo == "Este Año")
        {
            currentStart = new DateTime(fechaActual.Year, 1, 1);
            currentEnd = currentStart.Value.AddYears(1).AddTicks(-1);
            
            prevStart = currentStart.Value.AddYears(-1);
            prevEnd = currentStart.Value.AddTicks(-1);
        }
        else if (filtroTiempo == "Personalizado" && rangoFechasCustom?.Start != null && rangoFechasCustom?.End != null)
        {
            currentStart = rangoFechasCustom.Start.Value.Date;
            currentEnd = rangoFechasCustom.End.Value.Date.AddDays(1).AddTicks(-1);
            
            TimeSpan duracion = currentEnd.Value - currentStart.Value;
            prevEnd = currentStart.Value.AddTicks(-1);
            prevStart = prevEnd.Value.Add(-duracion);
        }
        else
        {
            mostrarCrecimiento = false; 
        }

        var queryActual = todasLasInscripciones.AsQueryable();
        var queryAnterior = todasLasInscripciones.AsQueryable();

        if (currentStart.HasValue && currentEnd.HasValue)
        {
            queryActual = queryActual.Where(e => e.EnrollmentDate >= currentStart.Value && e.EnrollmentDate <= currentEnd.Value);
        }
        if (prevStart.HasValue && prevEnd.HasValue)
        {
            queryAnterior = queryAnterior.Where(e => e.EnrollmentDate >= prevStart.Value && e.EnrollmentDate <= prevEnd.Value);
        }

        if (filtroAsesor != "Todos")
        {
            queryActual = queryActual.Where(e => e.AsesorAsignado == filtroAsesor);
            queryAnterior = queryAnterior.Where(e => e.AsesorAsignado == filtroAsesor);
        }

        var lista = queryActual.ToList();
        var listaPrev = queryAnterior.ToList();

        // -------------------------------------------------------------
        // CÁLCULO DE TARJETAS (KPIs) Y COBRANZA REAL (NUEVO)
        // -------------------------------------------------------------
        totalInscritos = lista.Count;
        totalIngresos = lista.Sum(e => e.MontoPlazo * (e.NumeroPlazos > 0 ? e.NumeroPlazos : 1));

        totalCobranzaReal = 0;
        foreach (var inscripcion in lista)
        {
            // Sumamos todos los pagos asociados EXACTAMENTE al alumno y curso de esta inscripción filtrada
            var pagosDeEstaInscripcion = todosLosPagos
                .Where(p => p.StudentId == inscripcion.StudentId && p.CourseId == inscripcion.CourseId)
                .Sum(p => p.Amount);
                
            totalCobranzaReal += pagosDeEstaInscripcion;
        }

        // Evitamos que el porcentaje rompa la barra visual si los alumnos pagan por adelantado (más del 100%)
        porcentajeCobranza = totalIngresos > 0 ? (totalCobranzaReal / totalIngresos) * 100 : 0;
        if (porcentajeCobranza > 100) porcentajeCobranza = 100;

        carteraVencida = totalIngresos - totalCobranzaReal;
        if (carteraVencida < 0) carteraVencida = 0;

        int prevInscritos = listaPrev.Count;
        double prevIngresos = listaPrev.Sum(e => e.MontoPlazo * (e.NumeroPlazos > 0 ? e.NumeroPlazos : 1));

        crecimientoInscritos = prevInscritos == 0 ? (totalInscritos > 0 ? 100 : 0) : ((double)(totalInscritos - prevInscritos) / prevInscritos) * 100;
        crecimientoIngresos = prevIngresos == 0 ? (totalIngresos > 0 ? 100 : 0) : ((totalIngresos - prevIngresos) / prevIngresos) * 100;

        var topCurso = lista.GroupBy(e => e.CourseId)
                            .OrderByDescending(g => g.Count())
                            .FirstOrDefault();
                            
        if (topCurso != null && !string.IsNullOrEmpty(topCurso.Key))
        {
            var nombre = todosLosCursos.FirstOrDefault(c => c.Id == topCurso.Key)?.Name;
            cursoEstrella = nombre ?? "Curso Desconocido";
        }
        else
        {
            cursoEstrella = "Sin registros";
        }

        var topAsesor = lista.Where(e => !string.IsNullOrWhiteSpace(e.AsesorAsignado))
                             .GroupBy(e => e.AsesorAsignado)
                             .OrderByDescending(g => g.Count())
                             .FirstOrDefault();
                             
        mejorAsesor = topAsesor != null ? topAsesor.Key : (filtroAsesor == "Todos" ? "Sin Asignar" : filtroAsesor);

        // -------------------------------------------------------------
        // CÁLCULO PARA GRÁFICAS Y TABLA DE FINANZAS
        // -------------------------------------------------------------
        var gruposCursos = lista.GroupBy(e => e.CourseId).ToList();
        
        List<double> datosPie = new();
        List<string> etiquetasPie = new();
        desgloseCursos.Clear(); 

        foreach (var grupo in gruposCursos)
        {
            var nombreCurso = todosLosCursos.FirstOrDefault(c => c.Id == grupo.Key)?.Name ?? "Desconocido";
            int cantidadInscritos = grupo.Count();
            
            double ingresoPorEsteCurso = grupo.Sum(e => e.MontoPlazo * (e.NumeroPlazos > 0 ? e.NumeroPlazos : 1));

            datosPie.Add(cantidadInscritos);
            etiquetasPie.Add($"{nombreCurso} ({cantidadInscritos})");

            desgloseCursos.Add(new DesgloseCurso
            {
                NombreCurso = nombreCurso,
                Cantidad = cantidadInscritos,
                IngresoTotal = ingresoPorEsteCurso
            });
        }

        dataCursos = datosPie.ToArray();
        labelsCursos = etiquetasPie.ToArray();
        desgloseCursos = desgloseCursos.OrderByDescending(d => d.IngresoTotal).ToList();

        // -------------------------------------------------------------
        // CÁLCULO PARA GRÁFICA DE BARRAS (Ventas por Asesor)
        // -------------------------------------------------------------
        var gruposAsesores = lista.GroupBy(e => string.IsNullOrWhiteSpace(e.AsesorAsignado) ? "Venta Online / Sin Asesor" : e.AsesorAsignado)
                                  .OrderByDescending(g => g.Count())
                                  .ToList();

        List<double> datosBarras = new();
        List<string> etiquetasBarras = new();

        foreach (var grupo in gruposAsesores)
        {
            datosBarras.Add(grupo.Count());
            etiquetasBarras.Add(grupo.Key);
        }

        SeriesAsesores = new List<ChartSeries<double>>()
        {
            new ChartSeries<double>() { Name = "Inscripciones", Data = datosBarras.ToArray() }
        };
        labelsAsesores = etiquetasBarras.ToArray();
    }

    private async Task DescargarReportePDF()
    {
        try
        {
            generandoPdf = true;
            StateHasChanged();
            
            await Task.Delay(100); 

            var pdfBytes = GeneratePdfDocument();
            var fileName = $"Reporte_Ventas_{DateTime.Now:yyyyMMdd}.pdf";

            var base64 = Convert.ToBase64String(pdfBytes);
            var js = $"var a = document.createElement('a'); a.href = 'data:application/pdf;base64,{base64}'; a.download = '{fileName}'; document.body.appendChild(a); a.click(); document.body.removeChild(a);";
            await JSRuntime.InvokeVoidAsync("eval", js);

            Snackbar.Add("Reporte PDF descargado exitosamente.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al generar el PDF: {ex.Message}", Severity.Error);
        }
        finally
        {
            generandoPdf = false;
            StateHasChanged();
        }
    }

    private byte[] GeneratePdfDocument()
    {
        return Document.Create(container =>
        {
            container.Page(page =>
            {
                page.Size(QuestPDF.Helpers.PageSizes.Letter);
                page.Margin(2, QuestPDF.Infrastructure.Unit.Centimetre);
                page.PageColor(QuestPDF.Helpers.Colors.White);
                page.DefaultTextStyle(x => x.FontSize(10).FontFamily("Arial"));

                page.Header().Row(row =>
                {
                    if (!string.IsNullOrEmpty(configuracion.LogoBase64))
                    {
                        var base64Logo = configuracion.LogoBase64.Contains(",") ? configuracion.LogoBase64.Substring(configuracion.LogoBase64.IndexOf(",") + 1) : configuracion.LogoBase64;
                        var logoBytes = Convert.FromBase64String(base64Logo);
                        row.ConstantItem(60).Image(logoBytes);
                        row.ConstantItem(15);
                    }

                    row.RelativeItem().Column(col =>
                    {
                        col.Item().Text(string.IsNullOrEmpty(configuracion.NombreEscuela) ? "Institución Educativa" : configuracion.NombreEscuela).SemiBold().FontSize(16).FontColor(QuestPDF.Helpers.Colors.Blue.Darken2);
                        col.Item().Text("REPORTE FINANCIERO Y DE VENTAS").Bold().FontSize(12).FontColor(QuestPDF.Helpers.Colors.Grey.Darken3);
                        
                        string periodoTexto = filtroTiempo == "Personalizado" 
                            ? $"Del {rangoFechasCustom.Start:dd/MMM/yyyy} al {rangoFechasCustom.End:dd/MMM/yyyy}" 
                            : filtroTiempo;
                        
                        string textoFiltroAsesor = filtroAsesor == "Todos" ? "Todos los Asesores" : $"Asesor: {filtroAsesor}";
                        col.Item().Text($"Periodo: {periodoTexto} | {textoFiltroAsesor}").FontSize(10);
                    });
                });

                page.Content().PaddingVertical(1, QuestPDF.Infrastructure.Unit.Centimetre).Column(x =>
                {
                    x.Spacing(15);
                    
                    // AÑADIMOS LA COBRANZA REAL Y CARTERA VENCIDA AL PDF
                    x.Item().Background(QuestPDF.Helpers.Colors.Grey.Lighten4).Padding(10).Row(row =>
                    {
                        row.RelativeItem().Column(c => { c.Item().Text("Ingresos Proyectados").FontSize(9).FontColor(QuestPDF.Helpers.Colors.Grey.Darken2); c.Item().Text(totalIngresos.ToString("C")).SemiBold().FontSize(12).FontColor(QuestPDF.Helpers.Colors.Grey.Darken3); });
                        row.RelativeItem().Column(c => { c.Item().Text("Cobranza Real").FontSize(9).FontColor(QuestPDF.Helpers.Colors.Grey.Darken2); c.Item().Text(totalCobranzaReal.ToString("C")).SemiBold().FontSize(12).FontColor(QuestPDF.Helpers.Colors.Blue.Darken2); });
                        row.RelativeItem().Column(c => { c.Item().Text("Cartera Vencida").FontSize(9).FontColor(QuestPDF.Helpers.Colors.Grey.Darken2); c.Item().Text(carteraVencida.ToString("C")).SemiBold().FontSize(12).FontColor(QuestPDF.Helpers.Colors.Red.Medium); });
                        row.RelativeItem().Column(c => { c.Item().Text("Total Inscripciones").FontSize(9).FontColor(QuestPDF.Helpers.Colors.Grey.Darken2); c.Item().Text(totalInscritos.ToString()).SemiBold().FontSize(12); });
                    });

                    x.Item().LineHorizontal(1).LineColor(QuestPDF.Helpers.Colors.Grey.Lighten2);

                    x.Item().Text("DESGLOSE POR CURSO").SemiBold().FontSize(12).FontColor(QuestPDF.Helpers.Colors.Blue.Darken3);
                    
                    x.Item().Table(table =>
                    {
                        table.ColumnsDefinition(columns =>
                        {
                            columns.RelativeColumn(3); 
                            columns.RelativeColumn(1); 
                            columns.RelativeColumn(1.5f); 
                        });

                        table.Header(header =>
                        {
                            header.Cell().BorderBottom(1).PaddingBottom(5).Text("Curso / Programa").SemiBold();
                            header.Cell().BorderBottom(1).PaddingBottom(5).AlignCenter().Text("Inscripciones").SemiBold();
                            header.Cell().BorderBottom(1).PaddingBottom(5).AlignRight().Text("Monto Proyectado").SemiBold();
                        });

                        foreach (var item in desgloseCursos)
                        {
                            table.Cell().PaddingVertical(5).BorderBottom(1).BorderColor(QuestPDF.Helpers.Colors.Grey.Lighten4).Text(item.NombreCurso);
                            table.Cell().PaddingVertical(5).BorderBottom(1).BorderColor(QuestPDF.Helpers.Colors.Grey.Lighten4).AlignCenter().Text(item.Cantidad.ToString());
                            table.Cell().PaddingVertical(5).BorderBottom(1).BorderColor(QuestPDF.Helpers.Colors.Grey.Lighten4).AlignRight().Text(item.IngresoTotal.ToString("C"));
                        }
                        
                        table.Cell().PaddingTop(10).Text("");
                        table.Cell().PaddingTop(10).AlignCenter().Text("PROYECCIÓN TOTAL:").SemiBold().FontSize(12);
                        table.Cell().PaddingTop(10).AlignRight().Text(totalIngresos.ToString("C")).SemiBold().FontSize(12).FontColor(QuestPDF.Helpers.Colors.Green.Darken3);
                    });
                });
                
                page.Footer().AlignCenter().Text(x =>
                {
                    x.Span("Página ");
                    x.CurrentPageNumber();
                    x.Span(" de ");
                    x.TotalPages();
                    x.Span($" | Documento generado el {DateTime.Now:dd/MM/yyyy a las HH:mm hrs}");
                });
            });
        }).GeneratePdf();
    }
}
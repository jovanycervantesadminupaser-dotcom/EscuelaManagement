@page "/cursos"
@rendermode RenderMode.InteractiveServer
@using MudBlazor
@using EscuelaManagement.Data.Models
@using EscuelaManagement.Data.Services
@inject FirebaseService Firebase
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <MudText Typo="Typo.h4" GutterBottom="true" Color="Color.Primary">Gestión de Cursos</MudText>

    <MudGrid>
        <MudItem xs="12" md="5">
            <EditForm Model="@newCourse" OnValidSubmit="HandleSubmit">
                <MudCard Elevation="3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Color="Color.Secondary">
                                @(isEditing ? "Editar Curso Seleccionado" : "Nuevo Curso y Esquema de Pagos")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12">
                                <MudTextField Label="Nombre del Curso*" @bind-Value="newCourse.Name" Required="true" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="Horario (Ej. Lunes a Viernes 4-6 pm)" @bind-Value="newCourse.Schedule" Variant="Variant.Outlined" />
                            </MudItem>
                            
                            <MudItem xs="12">
                                <MudNumericField Label="Costo Una Sola Exhibición ($)*" @bind-Value="newCourse.SinglePaymentCost" Required="true" Variant="Variant.Outlined" Min="0" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudSwitch T="bool" @bind-Value="newCourse.AllowInstallments" Color="Color.Primary" Label="¿Ofrecer opción de pago a plazos?" />
                            </MudItem>

                            @if (newCourse.AllowInstallments)
                            {
                                <MudItem xs="12">
                                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true">Plazos Disponibles para este Curso</MudAlert>
                                    
                                    @if (newCourse.InstallmentOptions == null || !newCourse.InstallmentOptions.Any())
                                    {
                                        <MudText Typo="Typo.caption" Class="text-muted d-block my-2"><i>No se han agregado plazos todavía.</i></MudText>
                                    }
                                    else
                                    {
                                        <MudChipSet T="string" AllClosable="false" Class="my-2">
                                            @foreach (var opcion in newCourse.InstallmentOptions)
                                            {
                                                <MudChip @key="opcion" T="string" Color="Color.Secondary" Variant="Variant.Filled" OnClose="(() => RemoverPlazo(opcion))">
                                                    @opcion.InstallmentCount @opcion.InstallmentPeriod de @opcion.InstallmentAmount.ToString("C")
                                                </MudChip>
                                            }
                                        </MudChipSet>
                                    }
                                </MudItem>

                                <MudItem xs="4">
                                    <MudNumericField Label="Cant.*" @bind-Value="tempCount" Variant="Variant.Outlined" Min="1" />
                                </MudItem>
                                <MudItem xs="4">
                                    <MudSelect T="string" Label="Periodo*" @bind-Value="tempPeriod" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                                        <MudSelectItem Value="@("Semanas")">Semanas</MudSelectItem>
                                        <MudSelectItem Value="@("Quincenas")">Quincenas</MudSelectItem>
                                        <MudSelectItem Value="@("Meses")">Meses</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudNumericField Label="Monto ($)*" @bind-Value="tempAmount" Variant="Variant.Outlined" Min="0" />
                                </MudItem>
                                <MudItem xs="12" Class="d-flex justify-end">
                                    <MudButton OnClick="AgregarPlazoALista" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AddCircleOutline">
                                        Añadir Plazo
                                    </MudButton>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudCardContent>
                    <MudCardActions Class="pb-4 pr-4 d-flex gap-2 justify-end">
                        @if (isEditing)
                        {
                            <MudButton OnClick="CancelarEdicion" Variant="Variant.Text" Color="Color.Default">Cancelar</MudButton>
                        }
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="@(isEditing ? Color.Warning : Color.Primary)" StartIcon="@(isEditing ? Icons.Material.Filled.Save : Icons.Material.Filled.Add)">
                            @(isEditing ? "Guardar Cambios" : "Agregar Curso")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </EditForm>
        </MudItem>

        <MudItem xs="12" md="7">
            @if (isLoading)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
            }
            else
            {
                <div class="fade-in-suave">
                    <MudTable Items="@listaCursos" Elevation="3" Hover="true" Striped="true">
                        <ToolBarContent>
                            <MudText Typo="Typo.h6">Lista de Cursos Activos</MudText>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>Nombre / Horario</MudTh>
                            <MudTh>Una Exhibición</MudTh>
                            <MudTh>Esquemas a Plazos</MudTh>
                            <MudTh Style="text-align: right;">Acciones</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Nombre / Horario">
                                <MudText Typo="Typo.body1"><b>@context.Name</b></MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Schedule</MudText>
                            </MudTd>
                            <MudTd DataLabel="Una Exhibición">
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">
                                    @context.SinglePaymentCost.ToString("C")
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Esquemas a Plazos">
                                @if (context.AllowInstallments && context.InstallmentOptions != null && context.InstallmentOptions.Any())
                                {
                                    @foreach (var opcion in context.InstallmentOptions)
                                    {
                                        <MudText Typo="Typo.caption" Class="d-block mb-1">
                                            • <b>@opcion.InstallmentCount</b> @opcion.InstallmentPeriod de <b>@opcion.InstallmentAmount.ToString("C")</b>
                                        </MudText>
                                    }
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Error"><i>No disponible</i></MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="Acciones" Style="text-align: right;">
                                <div class="d-flex justify-end gap-2">
                                    <MudTooltip Text="Editar Curso" Arrow="true" Placement="Placement.Top">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="(() => IniciarEdicion(context))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Eliminar Curso" Arrow="true" Placement="Placement.Top">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="(() => ConfirmarEliminar(context))" />
                                    </MudTooltip>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Align="Align.Center" Class="pa-4">No se encontraron cursos registrados</MudText>
                        </NoRecordsContent>
                    </MudTable>
                </div>
            }
        </MudItem>
    </MudGrid>

    <MudMessageBox @ref="mbox" Title="Confirmar Eliminación">
        <MessageContent>
            ¿Estás seguro de que deseas eliminar el curso "<b>@cursoAEliminar?.Name</b>"? Esta acción borrará de forma permanente el registro en Firebase.
        </MessageContent>
        <YesButton><MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete">ELIMINAR</MudButton></YesButton>
        <CancelButton><MudButton Variant="Variant.Text" Color="Color.Default">CANCELAR</MudButton></CancelButton>
    </MudMessageBox>
</MudContainer>

@code {
    private MudMessageBox mbox = default!;
    private Course? cursoAEliminar;
    private Course newCourse = new();
    private List<Course> listaCursos = new();
    private bool isLoading = true;
    private bool isEditing = false;
    private int tempCount = 12;
    private string tempPeriod = "Semanas";
    private double tempAmount = 0;

    protected override async Task OnInitializedAsync() => await CargarCursos();

    private async Task CargarCursos()
    {
        try
        {
            isLoading = true;
            listaCursos = await Firebase.GetCoursesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar cursos: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AgregarPlazoALista()
    {
        if (tempAmount <= 0) { Snackbar.Add("El monto por plazo debe ser mayor a 0", Severity.Warning); return; }
        if (newCourse.InstallmentOptions == null) newCourse.InstallmentOptions = new List<InstallmentOption>();
        newCourse.InstallmentOptions.Add(new InstallmentOption { InstallmentCount = tempCount, InstallmentPeriod = tempPeriod, InstallmentAmount = tempAmount });
        tempAmount = 0;
        StateHasChanged();
    }

    private void RemoverPlazo(InstallmentOption opcion) { newCourse.InstallmentOptions.Remove(opcion); StateHasChanged(); }

    private void IniciarEdicion(Course cursoSeleccionado)
    {
        isEditing = true;
        newCourse = new Course { Id = cursoSeleccionado.Id, Name = cursoSeleccionado.Name, Schedule = cursoSeleccionado.Schedule, SinglePaymentCost = cursoSeleccionado.SinglePaymentCost, AllowInstallments = cursoSeleccionado.AllowInstallments, InstallmentOptions = cursoSeleccionado.InstallmentOptions != null ? new List<InstallmentOption>(cursoSeleccionado.InstallmentOptions) : new List<InstallmentOption>() };
        StateHasChanged();
    }

    private void CancelarEdicion() { isEditing = false; newCourse = new Course(); tempAmount = 0; StateHasChanged(); }

    private async Task ConfirmarEliminar(Course curso)
    {
        cursoAEliminar = curso;
        if (await mbox.ShowAsync() == true)
        {
            try { await Firebase.DeleteCourseAsync(curso.Id); Snackbar.Add("Curso eliminado con éxito", Severity.Success); if (isEditing && newCourse.Id == curso.Id) CancelarEdicion(); await CargarCursos(); }
            catch (Exception ex) { Snackbar.Add($"Error al eliminar el curso: {ex.Message}", Severity.Error); }
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (!newCourse.AllowInstallments) newCourse.InstallmentOptions.Clear();
            else if (newCourse.InstallmentOptions == null || !newCourse.InstallmentOptions.Any()) { Snackbar.Add("Habilitaste los plazos pero no añadiste ninguno a la lista.", Severity.Warning); return; }
            await Firebase.AddCourseAsync(newCourse);
            Snackbar.Add(isEditing ? "Curso actualizado con éxito" : "Curso registrado con éxito", Severity.Success);
            isEditing = false; newCourse = new Course(); await CargarCursos();
        }
        catch (Exception ex) { Snackbar.Add($"Error al procesar curso: {ex.Message}", Severity.Error); }
    }
}
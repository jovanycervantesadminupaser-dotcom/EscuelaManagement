@page "/reportes"
@rendermode RenderMode.InteractiveServer
@using MudBlazor
@using System.IO
@using EscuelaManagement.Data.Models
@using EscuelaManagement.Data.Services
@inject FirebaseService Firebase
@inject ISnackbar Snackbar
@inject PdfService Pdf
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <MudText Typo="Typo.h4" GutterBottom="true" Color="Color.Primary">Centro de Reportes</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-6 text-muted">Genera e imprime documentos oficiales de control escolar.</MudText>

    <MudTabs Elevation="3" Rounded="true" ApplyEffectsToContainer="true" Color="Color.Primary">
        
        <MudTabPanel Text="Listas de Asistencia" Icon="@Icons.Material.Filled.FormatListNumbered" Class="pa-6">
            <div class="fade-in-suave">
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" Label="Selecciona el Curso" ValueChanged="OnCursoListaChanged" Value="selectedCursoListaId" Variant="Variant.Outlined">
                            @foreach (var c in listaCursos)
                            {
                                <MudSelectItem Value="@c.Id">@c.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="8" Class="d-flex align-center">
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PictureAsPdf" 
                                   OnClick="ImprimirLista">
                            GENERAR FORMATO PDF
                        </MudButton>
                    </MudItem>
                </MudGrid>

                @if (alumnosLista.Any())
                {
                    <MudTable Items="@alumnosLista" Hover="true" Striped="true" Elevation="1" Class="mt-6 border-solid mud-border-lines-default border-2">
                        <ToolBarContent>
                            <MudText Typo="Typo.h6">Vista Previa: Alumnos en el Curso</MudText>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>#</MudTh>
                            <MudTh>Nombre del Alumno</MudTh>
                            <MudTh>Matrícula / ID</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@(alumnosLista.IndexOf(context) + 1)</MudTd>
                            <MudTd><b>@context.Name</b></MudTd>
                            <MudTd>@context.Id.Substring(0, 8).ToUpper()</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </div>
        </MudTabPanel>

        <MudTabPanel Text="Boletas de Calificaciones" Icon="@Icons.Material.Filled.WorkspacePremium" Class="pa-6">
            <div class="fade-in-suave">
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" Label="1. Selecciona el Curso" ValueChanged="OnCursoBoletaChangedAsync" Value="selectedCursoBoletaId" Variant="Variant.Outlined">
                            @foreach (var c in listaCursos)
                            {
                                <MudSelectItem Value="@c.Id">@c.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" Label="2. Selecciona el Alumno" ValueChanged="OnAlumnoBoletaChangedAsync" Value="selectedAlumnoBoletaId" Variant="Variant.Outlined" Disabled="@(!alumnosBoleta.Any())">
                            @foreach (var a in alumnosBoleta)
                            {
                                <MudSelectItem Value="@a.Id">@a.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4" Class="d-flex align-center">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Print" 
                                   OnClick="ImprimirBoleta">
                            IMPRIMIR BOLETA
                        </MudButton>
                    </MudItem>
                </MudGrid>

                @if (boletaPreview.Any())
                {
                    <MudTable Items="@boletaPreview" Hover="true" Striped="true" Elevation="1" Class="mt-6 border-solid mud-border-lines-default border-2">
                        <ToolBarContent>
                            <MudText Typo="Typo.h6">Vista Previa de Boleta</MudText>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>Materia</MudTh>
                            <MudTh>Profesor</MudTh>
                            <MudTh>Periodo</MudTh>
                            <MudTh Style="text-align:center;">Calificación</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.NombreMateria</b></MudTd>
                            <MudTd>@context.Profesor</MudTd>
                            <MudTd>@context.Periodo</MudTd>
                            <MudTd Style="text-align:center;">
                                <MudChip T="string" Color="@ObtenerColorNota(context.Nota)" Size="Size.Small">
                                    @context.Nota.ToString("0.0")
                                </MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </div>
        </MudTabPanel>
        
    </MudTabs> 
</MudContainer>

@code {
    private List<Course> listaCursos = new();
    private List<Student> listaAlumnos = new();
    private List<Enrollment> listaInscripciones = new();
    private List<Materia> listaMaterias = new();
    private List<Calificacion> listaCalificaciones = new();
    private ConfiguracionEscuela configuracionEscuela = new();

    private string selectedCursoListaId = "";
    private List<Student> alumnosLista = new();

    private string selectedCursoBoletaId = "";
    private string selectedAlumnoBoletaId = "";
    private List<Student> alumnosBoleta = new();
    private List<FilaBoleta> boletaPreview = new();

    protected override async Task OnInitializedAsync()
    {
        configuracionEscuela = await Firebase.GetConfiguracionAsync() ?? new();
        listaCursos = await Firebase.GetCoursesAsync() ?? new();
        listaAlumnos = await Firebase.GetAllStudentsAsync() ?? new();
        listaInscripciones = await Firebase.GetAllEnrollmentsAsync() ?? new();
        listaMaterias = await Firebase.GetMateriasAsync() ?? new();
        listaCalificaciones = await Firebase.GetAllCalificacionesAsync() ?? new();
    }

    private void OnCursoListaChanged(string cursoId)
    {
        selectedCursoListaId = cursoId;
        var inscripcionesDelCurso = listaInscripciones.Where(i => i.CourseId == cursoId).ToList();
        alumnosLista = listaAlumnos.Where(a => inscripcionesDelCurso.Any(i => i.StudentId == a.Id)).OrderBy(a => a.Name).ToList();
    }

    private async Task ImprimirLista()
    {
        if (string.IsNullOrEmpty(selectedCursoListaId)) 
        {
            Snackbar.Add("Selecciona un curso primero.", Severity.Warning);
            return;
        }
        
        if (!alumnosLista.Any())
        {
            Snackbar.Add("No hay alumnos inscritos en este curso.", Severity.Warning);
            return;
        }

        var curso = listaCursos.FirstOrDefault(c => c.Id == selectedCursoListaId);
        string nombreCurso = curso?.Name ?? "Curso";

        byte[] pdfBytes = Pdf.GenerarListaAsistencia(alumnosLista, nombreCurso, configuracionEscuela.NombreEscuela, configuracionEscuela.LogoBase64);

        using var stream = new MemoryStream(pdfBytes);
        var dotNetStreamRef = new DotNetStreamReference(stream: stream);
        
        await JS.InvokeVoidAsync("downloadFileFromStream", $"Lista_Asistencia_{nombreCurso.Replace(" ", "_")}.pdf", dotNetStreamRef);
        Snackbar.Add("Lista de asistencia descargada exitosamente.", Severity.Success);
    }

    private async Task OnCursoBoletaChangedAsync(string cursoId)
    {
        selectedCursoBoletaId = cursoId;
        selectedAlumnoBoletaId = "";
        boletaPreview.Clear();
        
        listaInscripciones = await Firebase.GetAllEnrollmentsAsync() ?? new();
        
        var inscripcionesDelCurso = listaInscripciones.Where(i => i.CourseId == cursoId).ToList();
        alumnosBoleta = listaAlumnos.Where(a => inscripcionesDelCurso.Any(i => i.StudentId == a.Id)).OrderBy(a => a.Name).ToList();
    }

    private async Task OnAlumnoBoletaChangedAsync(string alumnoId)
    {
        selectedAlumnoBoletaId = alumnoId;
        
        listaCalificaciones = await Firebase.GetAllCalificacionesAsync() ?? new();
        listaMaterias = await Firebase.GetMateriasAsync() ?? new();

        boletaPreview.Clear();
        
        var notasDelAlumno = listaCalificaciones.Where(c => c.AlumnoId == alumnoId).ToList();

        foreach (var nota in notasDelAlumno)
        {
            var materiaInfo = listaMaterias.FirstOrDefault(m => m.Id == nota.MateriaId);
            
            boletaPreview.Add(new FilaBoleta
            {
                NombreMateria = materiaInfo?.Nombre ?? "Materia Desconocida",
                Profesor = materiaInfo?.Profesor ?? "Sin Profesor",
                Periodo = nota.Periodo,
                Nota = nota.Valor
            });
        }
        
        boletaPreview = boletaPreview.OrderBy(b => b.NombreMateria).ThenBy(b => b.Periodo).ToList();
        StateHasChanged();

        if (!boletaPreview.Any())
        {
            Snackbar.Add("Este alumno no tiene calificaciones registradas.", Severity.Error);
        }
    }

    private async Task ImprimirBoleta()
    {
        if (string.IsNullOrEmpty(selectedAlumnoBoletaId))
        {
            Snackbar.Add("Por favor, selecciona un alumno.", Severity.Warning);
            return;
        }

        if (!boletaPreview.Any()) 
        {
            Snackbar.Add("El alumno no tiene calificaciones para imprimir.", Severity.Error);
            return;
        }

        var alumno = listaAlumnos.FirstOrDefault(a => a.Id == selectedAlumnoBoletaId);
        var curso = listaCursos.FirstOrDefault(c => c.Id == selectedCursoBoletaId);
        
        if (alumno == null) return;
        string nombreCurso = curso?.Name ?? "Curso";

        var listaDto = boletaPreview.Select(b => new FilaBoletaDto
        {
            NombreMateria = b.NombreMateria,
            Profesor = b.Profesor,
            Periodo = b.Periodo,
            Nota = b.Nota
        }).ToList();

        byte[] pdfBytes = Pdf.GenerarBoleta(alumno, listaDto, nombreCurso, configuracionEscuela.NombreEscuela, configuracionEscuela.LogoBase64);

        using var stream = new MemoryStream(pdfBytes);
        var dotNetStreamRef = new DotNetStreamReference(stream: stream);
        
        await JS.InvokeVoidAsync("downloadFileFromStream", $"Boleta_{alumno.Name?.Replace(" ", "_")}.pdf", dotNetStreamRef);
        Snackbar.Add($"Boleta de {alumno.Name} generada correctamente.", Severity.Success);
    }

    private Color ObtenerColorNota(double nota)
    {
        if (nota < 6.0) return Color.Error;
        if (nota >= 9.0) return Color.Success;
        return Color.Warning;
    }

    public class FilaBoleta
    {
        public string NombreMateria { get; set; } = "";
        public string Profesor { get; set; } = "";
        public string Periodo { get; set; } = "";
        public double Nota { get; set; }
    }
}
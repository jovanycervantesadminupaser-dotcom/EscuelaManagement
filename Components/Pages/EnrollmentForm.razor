@page "/inscripciones"
@rendermode RenderMode.InteractiveServer
@using MudBlazor
@using EscuelaManagement.Data.Models
@using EscuelaManagement.Data.Services
@using Google.Cloud.Firestore
@using QuestPDF.Fluent
@inject FirebaseService Firebase
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <MudText Typo="Typo.h4" GutterBottom="true" Color="Color.Primary">Ficha de Inscripción</MudText>

    <MudCard Elevation="2" Class="mb-4 pa-4" Style="background-color: #f9f9f9;">
        <MudGrid Class="d-flex align-center">
            <MudItem xs="12" md="7">
                <MudAutocomplete T="Student" 
                                 Label="Buscar Alumno Inscrito previamente (Nombre o Apellido)" 
                                 Value="selectedStudent" 
                                 ValueChanged="OnStudentSelected"
                                 SearchFunc="@SearchStudents" 
                                 ToStringFunc="@DisplayAlumno"
                                 Variant="Variant.Outlined" 
                                 AdornmentIcon="@Icons.Material.Filled.Search" 
                                 AdornmentColor="Color.Primary" 
                                 Clearable="true" 
                                 Placeholder="Escribe para buscar..."/>
            </MudItem>
            <MudItem xs="12" md="5">
                @if (isExistingStudent)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="w-100">
                        Alumno existente: Se creará un nuevo historial de curso para este ID.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Text" Dense="true" Class="w-100">
                        Modo: Nuevo Registro de Alumno.
                    </MudAlert>
                }
            </MudItem>
        </MudGrid>
    </MudCard>

    <MudForm @ref="form" @bind-IsValid="@success">
        <MudCard Elevation="3">
            <MudCardContent>
                
                <MudGrid Class="mb-4">
                    <MudItem xs="12" Class="d-flex flex-column align-center justify-center">
                        @if (isCameraOpen)
                        {
                            <MudPaper Class="pa-3 mb-3 d-flex flex-column align-center" Elevation="3" Style="background-color: #f5f5f5;">
                                <video id="cameraVideo" width="320" height="240" autoplay style="border-radius: 8px; background-color: black;"></video>
                                <div class="mt-3 d-flex gap-4">
                                    <MudButton OnClick="CapturarFoto" Color="Color.Success" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Camera">Tomar Foto</MudButton>
                                    <MudButton OnClick="CerrarCamara" Color="Color.Error" Variant="Variant.Text">Cancelar</MudButton>
                                </div>
                            </MudPaper>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(student.PhotoBase64))
                            {
                                <MudImage Src="@student.PhotoBase64" Width="150" Height="150" ObjectFit="ObjectFit.Cover" Elevation="4" Class="rounded-lg mb-3" />
                            }
                            else
                            {
                                <MudPaper Width="150px" Height="150px" Class="d-flex align-center justify-center rounded-lg mb-3" Elevation="0" Style="background-color: #e0e0e0;">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 5rem;" Color="Color.Default" />
                                </MudPaper>
                            }
                            
                            <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                                <MudButton HtmlTag="label" for="fileInput" StartIcon="@Icons.Material.Filled.FileUpload">Subir Archivo</MudButton>
                                <MudButton OnClick="AbrirCamara" StartIcon="@Icons.Material.Filled.CameraAlt">Usar Cámara</MudButton>
                            </MudButtonGroup>
                            <InputFile id="fileInput" OnChange="UploadPhoto" accept=".jpg,.jpeg,.png" style="display: none;" />
                        }
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.h6" Class="mt-2 mb-4" Color="Color.Secondary">1. Datos del Alumno</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Nombre(s)*" @bind-Value="student.Name" Required="true" RequiredError="El nombre es obligatorio" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Apellido Paterno*" @bind-Value="student.PaternalLastName" Required="true" RequiredError="El apellido paterno es obligatorio" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Apellido Materno" @bind-Value="student.MaternalLastName" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker T="DateTime?" Label="Fecha de Nacimiento" @bind-Date="tempDate" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Teléfono del Alumno" @bind-Value="student.Phone" Variant="Variant.Outlined" MaxLength="10" InputType="InputType.Telephone" HelperText="10 dígitos" Disabled="@isExistingStudent" />
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Escuela de Procedencia" @bind-Value="student.PreviousSchool" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Escuela a Ingresar" @bind-Value="student.TargetSchool" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-6" />

                <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Secondary">2. Datos del Tutor / Contacto</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Nombre del Tutor" @bind-Value="student.Guardian.Name" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Apellidos" @bind-Value="student.Guardian.PaternalLastName" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Parentesco (Ej. Madre, Tío)" @bind-Value="student.Guardian.Relationship" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Teléfono del Tutor" @bind-Value="student.Guardian.Phone" Variant="Variant.Outlined" MaxLength="10" InputType="InputType.Telephone" HelperText="10 dígitos" Disabled="@isExistingStudent" />
                    </MudItem>
                    
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Correo Electrónico del Tutor*" @bind-Value="student.Guardian.Email" Variant="Variant.Outlined" InputType="InputType.Email" Required="true" RequiredError="El correo es obligatorio" Disabled="@isExistingStudent" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-6" />

                <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Secondary">3. Dirección</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Calle" @bind-Value="student.Address.Street" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudTextField T="string" Label="Núm. Exterior" @bind-Value="student.Address.ExtNumber" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudTextField T="string" Label="Núm. Interior" @bind-Value="student.Address.IntNumber" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Colonia" @bind-Value="student.Address.Neighborhood" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Municipio / Alcaldía" @bind-Value="student.Address.Municipality" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudTextField T="string" Label="Estado" @bind-Value="student.Address.State" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudTextField T="string" Label="Código Postal" @bind-Value="student.Address.ZipCode" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-6" />

                <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Secondary">4. Detalles de Inscripción y Esquema Financiero</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        @* AL CAMBIAR DE CURSO, SE LLAMA A OnCourseSelected PARA ACTUALIZAR PLAZOS *@
                        <MudSelect T="string" Label="Seleccionar Curso*" Value="@enrollment.CourseId" ValueChanged="OnCourseSelected" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Required="true" RequiredError="Debe seleccionar un curso">
                            @foreach (var curso in cursosDisponibles)
                            {
                                <MudSelectItem T="string" Value="@curso.Id">@curso.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSelect T="string" Label="Turno del Curso*" @bind-Value="turnoSeleccionado" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Required="true" RequiredError="Debe seleccionar un turno">
                            <MudSelectItem T="string" Value="@("MATUTINO")">MATUTINO</MudSelectItem>
                            <MudSelectItem T="string" Value="@("VESPERTINO")">VESPERTINO</MudSelectItem>
                            <MudSelectItem T="string" Value="@("OTRO")">OTRO (Especificar)</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    @if (turnoSeleccionado == "OTRO")
                    {
                        <MudItem xs="12" md="4">
                            <MudTextField T="string" Label="Especifique el Turno*" @bind-Value="turnoManual" Variant="Variant.Outlined" Required="true" RequiredError="Especifique el turno" />
                        </MudItem>
                    }

                    <MudItem xs="12" md="4">
                        @* AL CAMBIAR EL DESCUENTO, SE RECALCULA EL PRECIO BLOQUEADO *@
                        <MudNumericField T="double" Label="Descuento Aplicado (%)" Value="@enrollment.DiscountAmount" ValueChanged="OnDiscountChanged" Variant="Variant.Outlined" Min="0" Max="100" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Percent" />
                    </MudItem>

                    <MudItem xs="12" md="4">
                        @* AL CAMBIAR DE PLAZO, SE LLAMA A OnTipoPlazoSelected PARA AUTO-RELLENAR *@
                        <MudSelect T="string" Label="Esquema / Plazo de Pago*" Value="@enrollment.TipoPlazo" ValueChanged="OnTipoPlazoSelected" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Required="true" RequiredError="Debe definir el método de cobro" Disabled="@(currentCourse == null)">
                            @foreach (var plan in availablePaymentPlans)
                            {
                                <MudSelectItem T="string" Value="@plan">@plan</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @if (enrollment.TipoPlazo != "Una Sola Exhibición" && !string.IsNullOrEmpty(enrollment.TipoPlazo))
                    {
                        <MudItem xs="6" md="4">
                            @* CASILLAS EN MODO READONLY: CERO ERRORES HUMANOS *@
                            <MudNumericField T="int" Label="Cantidad de Plazos*" @bind-Value="enrollment.NumeroPlazos" Variant="Variant.Outlined" Min="1" ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="6" md="4">
                            <MudNumericField T="double" Label="Monto por Plazo ($)*" @bind-Value="enrollment.MontoPlazo" Variant="Variant.Outlined" Min="0.1" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" ReadOnly="true" />
                        </MudItem>
                    }
                    
                    <MudItem xs="12" Class="mt-4">
                        <MudCheckBox T="bool" @bind-Value="aceptaRetiroSinTutor" Label="Autorización para que el alumno se retire del plantel sin el tutor" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudCheckBox T="bool" @bind-Value="imprimirTerminos" Label="Imprimir Términos y Condiciones" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudCheckBox T="bool" @bind-Value="imprimirGarantia" Label="Imprimir Póliza de Garantía" Color="Color.Primary" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-6" />

                @* --- NUEVA SECCIÓN 5: ASIGNACIÓN DE ASESOR (VENTA) --- *@
                <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Secondary">5. Control Interno (Venta)</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string" Label="Ejecutivo / Asesor que realizó la inscripción" @bind-Value="enrollment.AsesorAsignado" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Clearable="true" Placeholder="Opcional: Seleccione un asesor">
                            @if(listaUsuarios != null && listaUsuarios.Any())
                            {
                                @foreach (var usuario in listaUsuarios.Where(u => u.Activo))
                                {
                                    <MudSelectItem T="string" Value="@usuario.Nombre">@usuario.Nombre (@usuario.Rol)</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                @* ----------------------------------------------------- *@

            </MudCardContent>

            <MudCardActions Class="pb-4 pr-4 flex-column align-end">
                @if (!registroCompletado)
                {
                    <div class="d-flex gap-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Email" OnClick="GuardarYEnviarCorreo" Disabled="@enviandoCorreo">
                            @if (enviandoCorreo)
                            {
                                <MudProgressCircular T="string" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>ENVIANDO...</span>
                            }
                            else
                            {
                                <span>GUARDAR Y ENVIAR POR CORREO</span>
                            }
                        </MudButton>

                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" StartIcon="@Icons.Material.Filled.FileDownload" OnClick="GuardarYDescargar" Disabled="@enviandoCorreo">
                            GUARDAR Y DESCARGAR PDF
                        </MudButton>
                    </div>
                }
                else
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Class="mb-3 w-100">
                        ¡Operación completada exitosamente!
                    </MudAlert>
                    
                    <div class="d-flex gap-3">
                        <MudButton Variant="Variant.Filled" Style="background-color: #25D366; color: white;" StartIcon="@Icons.Custom.Brands.WhatsApp" OnClick="CompartirWhatsApp">
                            Notificar WhatsApp
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="LimpiarFormulario">
                            NUEVA INSCRIPCIÓN
                        </MudButton>
                    </div>
                }
            </MudCardActions>
        </MudCard>
    </MudForm>
</MudContainer>

@code {
    private MudForm form = default!;
    private bool success;

    private Student student = new();
    private Enrollment enrollment = new();
    private DateTime? tempDate;
    private ConfiguracionEscuela configuracionEscuela = new();
    
    private List<Course> cursosDisponibles = new();
    private List<Student> listaAlumnosCompletos = new(); 
    private List<Usuario> listaUsuarios = new(); // Nueva lista para cargar a los empleados
    private Student? selectedStudent;
    
    // Variables para el cerebro financiero
    private Course? currentCourse;
    private List<string> availablePaymentPlans = new();

    private bool isExistingStudent = false;
    private bool isCameraOpen = false;

    private bool aceptaRetiroSinTutor = false;
    private bool imprimirTerminos = false;
    private bool imprimirGarantia = false;
    private string turnoSeleccionado = "";
    private string turnoManual = "";

    private bool registroCompletado = false;
    private bool enviandoCorreo = false;
    private byte[]? lastGeneratedPdfBytes;
    private string tipoAccion = "descargar";

    protected override async Task OnInitializedAsync()
    {
        QuestPDF.Settings.License = QuestPDF.Infrastructure.LicenseType.Community;
        await RecargarDatosDesdeFirebase();
    }

    private async Task RecargarDatosDesdeFirebase()
    {
        try
        {
            configuracionEscuela = await Firebase.GetConfiguracionAsync() ?? new();
            cursosDisponibles = await Firebase.GetCoursesAsync();
            listaAlumnosCompletos = await Firebase.GetAllStudentsAsync();
            
            // Cargamos la lista de empleados para el selector de ventas
            listaUsuarios = await Firebase.GetUsuariosAsync() ?? new(); 
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al sincronizar con Firebase: {ex.Message}", Severity.Error);
        }
    }

    // --- CEREBRO FINANCIERO: SELECCIÓN DE CURSO ---
    private void OnCourseSelected(string courseId)
    {
        enrollment.CourseId = courseId;
        currentCourse = cursosDisponibles.FirstOrDefault(c => c.Id == courseId);
        
        availablePaymentPlans.Clear();
        availablePaymentPlans.Add("Una Sola Exhibición");

        if (currentCourse != null && currentCourse.AllowInstallments && currentCourse.InstallmentOptions != null)
        {
            foreach (var opcion in currentCourse.InstallmentOptions)
            {
                if (!availablePaymentPlans.Contains(opcion.InstallmentPeriod))
                {
                    availablePaymentPlans.Add(opcion.InstallmentPeriod);
                }
            }
        }

        // Reseteamos el plazo para obligar a elegir de nuevo y evitamos que se queden precios viejos pegados
        enrollment.TipoPlazo = "";
        enrollment.NumeroPlazos = 0;
        enrollment.MontoPlazo = 0;
    }

    // --- CEREBRO FINANCIERO: RECALCULAR CON DESCUENTOS ---
    private void OnDiscountChanged(double value)
    {
        enrollment.DiscountAmount = value;
        CalcularEsquemaFinanciero();
    }

    // --- CEREBRO FINANCIERO: SELECCIÓN DE TIPO DE PLAZO ---
    private void OnTipoPlazoSelected(string tipoPlazo)
    {
        enrollment.TipoPlazo = tipoPlazo;
        CalcularEsquemaFinanciero();
    }

    // --- CEREBRO FINANCIERO: EL CÁLCULO MÁGICO ---
    private void CalcularEsquemaFinanciero()
    {
        if (currentCourse == null || string.IsNullOrEmpty(enrollment.TipoPlazo)) return;

        double factorDescuento = 1 - (enrollment.DiscountAmount / 100.0);

        if (enrollment.TipoPlazo == "Una Sola Exhibición")
        {
            enrollment.NumeroPlazos = 1;
            enrollment.MontoPlazo = currentCourse.SinglePaymentCost * factorDescuento;
        }
        else
        {
            var opcionSeleccionada = currentCourse.InstallmentOptions.FirstOrDefault(o => o.InstallmentPeriod == enrollment.TipoPlazo);
            if (opcionSeleccionada != null)
            {
                enrollment.NumeroPlazos = opcionSeleccionada.InstallmentCount;
                enrollment.MontoPlazo = opcionSeleccionada.InstallmentAmount * factorDescuento;
            }
        }
    }

    private string DisplayAlumno(Student? s)
    {
        return s == null ? "" : $"{s.Name} {s.PaternalLastName} {s.MaternalLastName}";
    }

    private Task<IEnumerable<Student>> SearchStudents(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult<IEnumerable<Student>>(listaAlumnosCompletos.Take(10));

        var filtrados = listaAlumnosCompletos.Where(s => 
            (s.Name?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.PaternalLastName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.MaternalLastName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false)
        );

        return Task.FromResult(filtrados);
    }

    private void OnStudentSelected(Student? alumnoSelected)
    {
        selectedStudent = alumnoSelected;
        
        if (alumnoSelected != null)
        {
            student = alumnoSelected;
            isExistingStudent = true;

            if (student.DateOfBirth != null)
            {
                tempDate = student.DateOfBirth.Value.ToDateTime();
            }
        }
        else
        {
            LimpiarFormulario();
        }
        StateHasChanged();
    }

    private void LimpiarFormulario()
    {
        student = new Student();
        enrollment = new Enrollment();
        tempDate = null;
        selectedStudent = null;
        currentCourse = null;
        availablePaymentPlans.Clear();
        isExistingStudent = false;
        aceptaRetiroSinTutor = false;
        imprimirTerminos = false;
        imprimirGarantia = false;
        turnoSeleccionado = "";
        turnoManual = "";
        registroCompletado = false;
        enviandoCorreo = false;
        lastGeneratedPdfBytes = null;
        tipoAccion = "descargar";
    }

    private async Task AbrirCamara()
    {
        isCameraOpen = true;
        StateHasChanged();
        await Task.Delay(100); 
        await JSRuntime.InvokeVoidAsync("cameraHelper.startCamera", "cameraVideo");
    }

    private async Task CapturarFoto()
    {
        try
        {
            Snackbar.Add("Procesando imagen...", Severity.Info);
            var base64 = await JSRuntime.InvokeAsync<string>("cameraHelper.takeSnapshot", "cameraVideo");
            student.PhotoBase64 = base64;
            await CerrarCamara();
            Snackbar.Add("¡Fotografía capturada con éxito!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al tomar la foto: {ex.Message}", Severity.Error);
            await CerrarCamara();
        }
    }

    private async Task CerrarCamara()
    {
        await JSRuntime.InvokeVoidAsync("cameraHelper.stopCamera");
        isCameraOpen = false;
        StateHasChanged();
    }

    private async Task UploadPhoto(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var buffer = memoryStream.ToArray();
            
            student.PhotoBase64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
    }

    private async Task GuardarYEnviarCorreo()
    {
        await form.ValidateAsync();
        if (form.IsValid)
        {
            tipoAccion = "correo";
            enviandoCorreo = true;
            StateHasChanged();
            await HandleSubmit();
        }
        else
        {
            Snackbar.Add("Por favor, completa todos los campos obligatorios marcados con *", Severity.Warning);
        }
    }

    private async Task GuardarYDescargar()
    {
        await form.ValidateAsync();
        if (form.IsValid)
        {
            tipoAccion = "descargar";
            enviandoCorreo = true; 
            StateHasChanged();
            await HandleSubmit();
        }
        else
        {
            Snackbar.Add("Por favor, completa todos los campos obligatorios marcados con *", Severity.Warning);
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (string.IsNullOrEmpty(student.Id))
            {
                student.Id = Guid.NewGuid().ToString();
            }

            if (tempDate.HasValue && !isExistingStudent)
            {
                student.DateOfBirth = Timestamp.FromDateTime(tempDate.Value.ToUniversalTime());
            }

            await Firebase.AddStudentAsync(student);

            enrollment.StudentId = student.Id;
            enrollment.EnrollmentDate = DateTime.UtcNow; 
            enrollment.Turno = turnoSeleccionado == "OTRO" ? turnoManual : turnoSeleccionado;

            if (enrollment.TipoPlazo == "Una Sola Exhibición")
            {
                var curso = cursosDisponibles.FirstOrDefault(c => c.Id == enrollment.CourseId);
                if (curso != null)
                {
                    double costoConDescuento = curso.SinglePaymentCost * (1 - (enrollment.DiscountAmount / 100.0));
                    enrollment.NumeroPlazos = 1;
                    enrollment.MontoPlazo = costoConDescuento;
                }
            }

            await Firebase.AddEnrollmentAsync(enrollment);

            var pdfBytes = GeneratePdfDocument();
            lastGeneratedPdfBytes = pdfBytes;

            await DescargarPdf(pdfBytes, $"Ficha_{student.Name}_{student.PaternalLastName}.pdf");

            if (tipoAccion == "correo")
            {
                await CompartirCorreoHibrido();
            }
            else
            {
                Snackbar.Add("Inscripción guardada de forma exitosa.", Severity.Success);
            }
            
            registroCompletado = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al procesar la inscripción: {ex.Message}", Severity.Error);
        }
        finally
        {
            enviandoCorreo = false;
            StateHasChanged(); 
        }
    }

    private async Task CompartirWhatsApp()
    {
        var telefono = student.Guardian.Phone;
        if (string.IsNullOrEmpty(telefono) || telefono.Length != 10)
        {
            telefono = student.Phone;
        }

        if (string.IsNullOrEmpty(telefono) || telefono.Length != 10)
        {
            Snackbar.Add("No hay un número válido de 10 dígitos registrado.", Severity.Warning);
            return;
        }

        var nombreDestinatario = string.IsNullOrEmpty(student.Guardian.Name) ? student.Name : student.Guardian.Name;
        var mensaje = Uri.EscapeDataString($"¡Hola {nombreDestinatario}! Confirmamos la inscripción exitosa de {student.Name} en {configuracionEscuela.NombreEscuela}. Por este medio le compartimos su Ficha de Inscripción oficial.");
        var url = $"https://wa.me/52{telefono}?text={mensaje}";
        await JSRuntime.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task CompartirCorreoHibrido()
    {
        if (string.IsNullOrWhiteSpace(student.Guardian.Email))
        {
            Snackbar.Add("El tutor no cuenta con una dirección de correo válida.", Severity.Warning);
            return;
        }

        try
        {
            var nombreTutor = string.IsNullOrEmpty(student.Guardian.Name) ? "Padre o Tutor" : student.Guardian.Name;
            var asunto = Uri.EscapeDataString("Confirmación de Inscripción - UPASER");
            var cuerpo = Uri.EscapeDataString($"Estimado(a) {nombreTutor},\n\nLe informamos que la inscripción de {student.Name} {student.PaternalLastName} ha sido procesada con éxito.\nPor favor, encuentre adjunta su Ficha de Inscripción oficial en formato PDF.\n\nSaludos cordiales,\nControl Escolar - UPASER");
            
            var mailtoUrl = $"mailto:{student.Guardian.Email}?subject={asunto}&body={cuerpo}";
            await JSRuntime.InvokeVoidAsync("open", mailtoUrl, "_self");

            Snackbar.Add("Ficha guardada localmente. Gestor de correo abierto.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al abrir el gestor de correo: {ex.Message}", Severity.Error);
        }
    }


@page "/inscripciones"
@rendermode RenderMode.InteractiveServer
@using MudBlazor
@using EscuelaManagement.Data.Models
@using EscuelaManagement.Data.Services
@using Google.Cloud.Firestore
@using QuestPDF.Fluent
@inject FirebaseService Firebase
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <MudText Typo="Typo.h4" GutterBottom="true" Color="Color.Primary">Ficha de Inscripción</MudText>

    <MudCard Elevation="2" Class="mb-4 pa-4" Style="background-color: #f9f9f9;">
        <MudGrid Class="d-flex align-center">
            <MudItem xs="12" md="7">
                <MudAutocomplete T="Student" 
                                 Label="Buscar Alumno Inscrito previamente (Nombre o Apellido)" 
                                 Value="selectedStudent" 
                                 ValueChanged="OnStudentSelected"
                                 SearchFunc="@SearchStudents" 
                                 ToStringFunc="@DisplayAlumno"
                                 Variant="Variant.Outlined" 
                                 AdornmentIcon="@Icons.Material.Filled.Search" 
                                 AdornmentColor="Color.Primary" 
                                 Clearable="true" 
                                 Placeholder="Escribe para buscar..."/>
            </MudItem>
            <MudItem xs="12" md="5">
                @if (isExistingStudent)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="w-100">
                        Alumno existente: Se creará un nuevo historial de curso para este ID.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Text" Dense="true" Class="w-100">
                        Modo: Nuevo Registro de Alumno.
                    </MudAlert>
                }
            </MudItem>
        </MudGrid>
    </MudCard>

    <EditForm Model="@student" OnValidSubmit="HandleSubmit">
        <MudCard Elevation="3">
            <MudCardContent>
                
                <MudGrid Class="mb-4">
                    <MudItem xs="12" Class="d-flex flex-column align-center justify-center">
                        @if (isCameraOpen)
                        {
                            <MudPaper Class="pa-3 mb-3 d-flex flex-column align-center" Elevation="3" Style="background-color: #f5f5f5;">
                                <video id="cameraVideo" width="320" height="240" autoplay style="border-radius: 8px; background-color: black;"></video>
                                <div class="mt-3 d-flex gap-4">
                                    <MudButton ButtonType="ButtonType.Button" OnClick="CapturarFoto" Color="Color.Success" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Camera">Tomar Foto</MudButton>
                                    <MudButton ButtonType="ButtonType.Button" OnClick="CerrarCamara" Color="Color.Error" Variant="Variant.Text">Cancelar</MudButton>
                                </div>
                            </MudPaper>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(student.PhotoBase64))
                            {
                                <MudImage Src="@student.PhotoBase64" Width="150" Height="150" ObjectFit="ObjectFit.Cover" Elevation="4" Class="rounded-lg mb-3" />
                            }
                            else
                            {
                                <MudPaper Width="150px" Height="150px" Class="d-flex align-center justify-center rounded-lg mb-3" Elevation="0" Style="background-color: #e0e0e0;">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 5rem;" Color="Color.Default" />
                                </MudPaper>
                            }
                            
                            <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                                <MudButton HtmlTag="label" for="fileInput" StartIcon="@Icons.Material.Filled.FileUpload">Subir Archivo</MudButton>
                                <MudButton ButtonType="ButtonType.Button" OnClick="AbrirCamara" StartIcon="@Icons.Material.Filled.CameraAlt">Usar Cámara</MudButton>
                            </MudButtonGroup>
                            <InputFile id="fileInput" OnChange="UploadPhoto" accept=".jpg,.jpeg,.png" style="display: none;" />
                        }
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.h6" Class="mt-2 mb-4" Color="Color.Secondary">1. Datos del Alumno</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Nombre(s)*" @bind-Value="student.Name" Required="true" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Apellido Paterno*" @bind-Value="student.PaternalLastName" Required="true" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Apellido Materno" @bind-Value="student.MaternalLastName" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker Label="Fecha de Nacimiento" @bind-Date="tempDate" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Teléfono del Alumno" @bind-Value="student.Phone" Variant="Variant.Outlined" Mask="@(new PatternMask("0000000000"))" HelperText="10 dígitos" Disabled="@isExistingStudent" />
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudTextField Label="Escuela de Procedencia" @bind-Value="student.PreviousSchool" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField Label="Escuela a Ingresar" @bind-Value="student.TargetSchool" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-6" />

                <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Secondary">2. Datos del Tutor / Contacto</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Nombre del Tutor" @bind-Value="student.Guardian.Name" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Apellidos" @bind-Value="student.Guardian.PaternalLastName" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Parentesco (Ej. Madre, Tío)" @bind-Value="student.Guardian.Relationship" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Teléfono del Tutor" @bind-Value="student.Guardian.Phone" Variant="Variant.Outlined" Mask="@(new PatternMask("0000000000"))" HelperText="10 dígitos" Disabled="@isExistingStudent" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-6" />

                <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Secondary">3. Dirección</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField Label="Calle" @bind-Value="student.Address.Street" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudTextField Label="Núm. Exterior" @bind-Value="student.Address.ExtNumber" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudTextField Label="Núm. Interior" @bind-Value="student.Address.IntNumber" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Colonia" @bind-Value="student.Address.Neighborhood" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField Label="Municipio / Alcaldía" @bind-Value="student.Address.Municipality" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudTextField Label="Estado" @bind-Value="student.Address.State" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudTextField Label="Código Postal" @bind-Value="student.Address.ZipCode" Variant="Variant.Outlined" Disabled="@isExistingStudent" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-6" />

                <MudText Typo="Typo.h6" Class="mb-4" Color="Color.Secondary">4. Detalles de Inscripción y Documentación Legal</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" Label="Seleccionar Curso*" @bind-Value="enrollment.CourseId" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Required="true">
                            @foreach (var curso in cursosDisponibles)
                            {
                                <MudSelectItem Value="@curso.Id">@curso.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSelect T="string" Label="Turno del Curso*" @bind-Value="turnoSeleccionado" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Required="true">
                            <MudSelectItem Value="@("MATUTINO")">MATUTINO</MudSelectItem>
                            <MudSelectItem Value="@("VESPERTINO")">VESPERTINO</MudSelectItem>
                            <MudSelectItem Value="@("OTRO")">OTRO (Especificar)</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    @if (turnoSeleccionado == "OTRO")
                    {
                        <MudItem xs="12" md="4">
                            <MudTextField Label="Especifique el Turno*" @bind-Value="turnoManual" Variant="Variant.Outlined" Required="true" />
                        </MudItem>
                    }

                    <MudItem xs="12" md="4">
                        <MudNumericField Label="Descuento Aplicado (%)" @bind-Value="enrollment.DiscountAmount" Variant="Variant.Outlined" Min="0" Max="100" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Percent" />
                    </MudItem>
                    
                    <MudItem xs="12" Class="mt-4">
                        <MudCheckBox @bind-Value="aceptaRetiroSinTutor" Label="Autorización para que el alumno se retire del plantel sin el tutor" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudCheckBox @bind-Value="imprimirTerminos" Label="Imprimir Términos y Condiciones" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudCheckBox @bind-Value="imprimirGarantia" Label="Imprimir Póliza de Garantía" Color="Color.Primary" />
                    </MudItem>
                </MudGrid>

            </MudCardContent>

            <MudCardActions Class="pb-4 pr-4">
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" Class="ml-auto" StartIcon="@Icons.Material.Filled.PictureAsPdf">
                    GUARDAR Y GENERAR PDF
                </MudButton>
            </MudCardActions>
        </MudCard>
    </EditForm>
</MudContainer>

@code {
    private Student student = new();
    private Enrollment enrollment = new();
    private DateTime? tempDate;
    private ConfiguracionEscuela configuracionEscuela = new();
    
    private List<Course> cursosDisponibles = new();
    private List<Student> listaAlumnosCompletos = new(); 
    private Student? selectedStudent;
    private bool isExistingStudent = false;
    private bool isCameraOpen = false;

    private bool aceptaRetiroSinTutor = false;
    private bool imprimirTerminos = false;
    private bool imprimirGarantia = false;
    private string turnoSeleccionado = "";
    private string turnoManual = "";

    protected override async Task OnInitializedAsync()
    {
        QuestPDF.Settings.License = QuestPDF.Infrastructure.LicenseType.Community;
        await RecargarDatosDesdeFirebase();
    }

    private async Task RecargarDatosDesdeFirebase()
    {
        try
        {
            configuracionEscuela = await Firebase.GetConfiguracionAsync() ?? new();
            cursosDisponibles = await Firebase.GetCoursesAsync();
            listaAlumnosCompletos = await Firebase.GetAllStudentsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al sincronizar con Firebase: {ex.Message}", Severity.Error);
        }
    }

    private string DisplayAlumno(Student? s)
    {
        return s == null ? "" : $"{s.Name} {s.PaternalLastName} {s.MaternalLastName}";
    }

    private Task<IEnumerable<Student>> SearchStudents(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult<IEnumerable<Student>>(listaAlumnosCompletos.Take(10));

        var filtrados = listaAlumnosCompletos.Where(s => 
            (s.Name?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.PaternalLastName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.MaternalLastName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false)
        );

        return Task.FromResult(filtrados);
    }

    private void OnStudentSelected(Student? alumnoSelected)
    {
        selectedStudent = alumnoSelected;
        
        if (alumnoSelected != null)
        {
            student = alumnoSelected;
            isExistingStudent = true;

            if (student.DateOfBirth != null)
            {
                tempDate = student.DateOfBirth.Value.ToDateTime();
            }
        }
        else
        {
            LimpiarFormulario();
        }
        StateHasChanged();
    }

    private void LimpiarFormulario()
    {
        student = new Student();
        enrollment = new Enrollment();
        tempDate = null;
        selectedStudent = null;
        isExistingStudent = false;
        aceptaRetiroSinTutor = false;
        imprimirTerminos = false;
        imprimirGarantia = false;
        turnoSeleccionado = "";
        turnoManual = "";
    }

    private async Task AbrirCamara()
    {
        isCameraOpen = true;
        StateHasChanged();
        await Task.Delay(100); 
        await JSRuntime.InvokeVoidAsync("cameraHelper.startCamera", "cameraVideo");
    }

    private async Task CapturarFoto()
    {
        try
        {
            Snackbar.Add("Procesando imagen...", Severity.Info);
            var base64 = await JSRuntime.InvokeAsync<string>("cameraHelper.takeSnapshot", "cameraVideo");
            student.PhotoBase64 = base64;
            await CerrarCamara();
            Snackbar.Add("¡Fotografía capturada con éxito!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al tomar la foto: {ex.Message}", Severity.Error);
            await CerrarCamara();
        }
    }

    private async Task CerrarCamara()
    {
        await JSRuntime.InvokeVoidAsync("cameraHelper.stopCamera");
        isCameraOpen = false;
        StateHasChanged();
    }

    private async Task UploadPhoto(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var buffer = memoryStream.ToArray();
            
            student.PhotoBase64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (string.IsNullOrEmpty(student.Id))
            {
                student.Id = Guid.NewGuid().ToString();
            }

            if (tempDate.HasValue && !isExistingStudent)
            {
                student.DateOfBirth = Timestamp.FromDateTime(tempDate.Value.ToUniversalTime());
            }

            await Firebase.AddStudentAsync(student);

            enrollment.StudentId = student.Id;
            enrollment.EnrollmentDate = DateTime.UtcNow; 
            
            enrollment.Turno = turnoSeleccionado == "OTRO" ? turnoManual : turnoSeleccionado;

            await Firebase.AddEnrollmentAsync(enrollment);

            var pdfBytes = GeneratePdfDocument();
            await DescargarPdf(pdfBytes, $"Ficha_{student.Name}_{student.PaternalLastName}.pdf");

            Snackbar.Add("Registro e Inscripción completados con éxito", Severity.Success);

            LimpiarFormulario();
            await RecargarDatosDesdeFirebase();
            StateHasChanged(); 
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al procesar la inscripción: {ex.Message}", Severity.Error);
        }
    }

    private byte[] GeneratePdfDocument()
    {
        string turnoFinal = turnoSeleccionado == "OTRO" ? turnoManual : turnoSeleccionado;

        return Document.Create(container =>
        {
            container.Page(page =>
            {
                page.Size(QuestPDF.Helpers.PageSizes.Letter);
                page.Margin(2, QuestPDF.Infrastructure.Unit.Centimetre);
                page.PageColor(QuestPDF.Helpers.Colors.White);
                page.DefaultTextStyle(x => x.FontSize(10).FontFamily("Arial"));

                page.Header().Row(row =>
                {
                    if (!string.IsNullOrEmpty(configuracionEscuela.LogoBase64))
                    {
                        var base64Logo = configuracionEscuela.LogoBase64.Contains(",") ? configuracionEscuela.LogoBase64.Substring(configuracionEscuela.LogoBase64.IndexOf(",") + 1) : configuracionEscuela.LogoBase64;
                        var logoBytes = Convert.FromBase64String(base64Logo);
                        row.ConstantItem(55).Image(logoBytes);
                        row.ConstantItem(15);
                    }

                    row.RelativeItem().Column(col =>
                    {
                        col.Item().Text(configuracionEscuela.NombreEscuela).SemiBold().FontSize(18).FontColor(QuestPDF.Helpers.Colors.Blue.Darken2);
                        col.Item().Text("FICHA DE INSCRIPCIÓN").Bold().FontSize(12).FontColor(QuestPDF.Helpers.Colors.Grey.Darken3);
                        col.Item().Text($"Fecha de registro: {DateTime.Now.ToString("dd/MM/yyyy")}").FontSize(9);
                    });

                    if (!string.IsNullOrEmpty(student.PhotoBase64))
                    {
                        var base64Data = student.PhotoBase64.Contains(",") ? student.PhotoBase64.Substring(student.PhotoBase64.IndexOf(",") + 1) : student.PhotoBase64;
                        var imageBytes = Convert.FromBase64String(base64Data);
                        row.ConstantItem(65).Image(imageBytes);
                    }
                });

                page.Content().PaddingVertical(1, QuestPDF.Infrastructure.Unit.Centimetre).Column(x =>
                {
                    x.Spacing(10);
                    
                    x.Item().Background(QuestPDF.Helpers.Colors.Grey.Lighten3).Padding(5).Text("1. Datos del Alumno").SemiBold();
                    x.Item().Text($"Nombre: {student.Name} {student.PaternalLastName} {student.MaternalLastName}");
                    x.Item().Text($"Teléfono: {(string.IsNullOrEmpty(student.Phone) ? "No registrado" : student.Phone)}");
                    
                    x.Item().Text($"Escuela de Procedencia: {(string.IsNullOrEmpty(student.PreviousSchool) ? "No registrado" : student.PreviousSchool)}");
                    x.Item().Text($"Escuela a Ingresar: {(string.IsNullOrEmpty(student.TargetSchool) ? "No registrado" : student.TargetSchool)}");
                    
                    x.Item().Background(QuestPDF.Helpers.Colors.Grey.Lighten3).Padding(5).Text("2. Tutor").SemiBold();
                    x.Item().Text($"Tutor: {student.Guardian.Name} {student.Guardian.PaternalLastName} ({student.Guardian.Relationship})");
                    x.Item().Text($"Teléfono Tutor: {(string.IsNullOrEmpty(student.Guardian.Phone) ? "No registrado" : student.Guardian.Phone)}");

                    x.Item().Background(QuestPDF.Helpers.Colors.Grey.Lighten3).Padding(5).Text("3. Dirección").SemiBold();
                    x.Item().Text($"{student.Address.Street} {student.Address.ExtNumber}, Col. {student.Address.Neighborhood}, {student.Address.Municipality}, {student.Address.State}. CP: {student.Address.ZipCode}");

                    x.Item().Background(QuestPDF.Helpers.Colors.Grey.Lighten3).Padding(5).Text("4. Curso Inscrito").SemiBold();
                    var nombreCurso = cursosDisponibles.FirstOrDefault(c => c.Id == enrollment.CourseId)?.Name ?? "No seleccionado";
                    x.Item().Text($"Curso: {nombreCurso} | Turno: {(string.IsNullOrEmpty(turnoFinal) ? "No asignado" : turnoFinal.ToUpper())}");
                    x.Item().Text($"Descuento Aplicado: {enrollment.DiscountAmount}%");

                    if (aceptaRetiroSinTutor)
                    {
                        x.Item().PaddingTop(20).Text(t => 
                        {
                            t.Span("AUTORIZACIÓN DE RETIRO").Bold().Underline();
                            t.EmptyLine();
                            t.Span($"Yo, autorizo que mi hijo(a): {student.Name} {student.PaternalLastName} {student.MaternalLastName} pueda retirarse de la institución sin que acuda alguna persona mayor de edad a recogerlo al plantel, deslindando de toda responsabilidad a UPASER después del horario de salida.");
                        });
                        
                        x.Item().PaddingTop(30).Row(row => {
                            row.RelativeItem().AlignCenter().Column(c => { 
                                c.Item().BorderBottom(1).BorderColor(QuestPDF.Helpers.Colors.Black).Width(60, QuestPDF.Infrastructure.Unit.Millimetre).Text(""); 
                                c.Item().Text("Firma del Padre o Tutor").FontSize(9); 
                            });
                        });
                    }
                });
            });

            if (imprimirGarantia)
            {
                container.Page(page =>
                {
                    page.Size(QuestPDF.Helpers.PageSizes.Letter);
                    page.Margin(2, QuestPDF.Infrastructure.Unit.Centimetre);
                    page.PageColor(QuestPDF.Helpers.Colors.White);
                    page.DefaultTextStyle(x => x.FontSize(10).FontFamily("Arial"));

                    page.Content().Column(c => {
                        c.Item().Text("PÓLIZA DE GARANTÍA").Bold().FontSize(14).AlignCenter();
                        c.Item().PaddingTop(15);

                        c.Item().Text("DERECHOS").Bold();
                        c.Item().Text("a) Recibir sus clases conforme lo señale su horario y fecha de evaluación.");
                        c.Item().Text("b) Conocer anticipadamente temarios, formas de trabajo y criterios de evaluación de cada una de las asignaturas.");
                        c.Item().Text("c) Ser tratado por sus docentes y autoridades educativas con cortesía, respeto y amabilidad.");
                        
                        c.Item().PaddingTop(10).Text("OBLIGACIONES").Bold();
                        c.Item().Text("a) Asistir a sus clases conforme al horario establecido, teniendo como margen de tiempo 10 min. Después de haber iniciado la clase, dos retardos equivalen a una falta.");
                        c.Item().Text("b) Respetar el tiempo de receso otorgado (30 min.).");
                        c.Item().Text("c) Ser respetuoso con sus compañeros, docentes y personal en general.");
                        c.Item().Text("d) Mantener orden y disciplina.");
                        c.Item().Text("e) Cumplir con tareas e investigaciones encomendados.");
                        c.Item().Text("f) Conservar y cuidar la institución.");
                        c.Item().Text("g) Cumplir en tiempo y forma con los pagos estipulados.");
                        c.Item().Text("El incumplimiento de cualquiera de las obligaciones es motivo de la perdida de garantía.").Italic();

                        c.Item().PaddingTop(10).Text("ANULACIÓN DE LA GARANTÍA").Bold();
                        c.Item().Text("• Tener menos del 90% de asistencias, tomando en cuenta que por día se pueden ver una o más clases; lo que equivale a una falta por materia.");
                        c.Item().Text("• Tener menos del 90% en entregas de tareas y actividades asignadas por el docente.");
                        c.Item().Text("• No a ver liquidado el total del curso antes de que finalice el mismo.");
                        c.Item().Text("• Tener menos de 80% en las evaluaciones que se harán por parte de UPASER.");
                        
                        c.Item().PaddingTop(10).Text("NOTA. El alumno podrá solicitar su garantía siempre y cuando cumpla con los requisitos antes mencionados.").Bold();

                        c.Item().PaddingTop(15).Text("CLAUSULA PARA USO DE MARKETING").Bold();
                        c.Item().Text("El alumno autoriza expresamente a UPASER a captar, reproducir y utilizar su imagen, nombre y/o voz a través de fotografías, grabaciones de video o cualquier otro medio audiovisual, con fines exclusivamente publicitarios, institucionales, informativos y/o académicos relacionados con las actividades de la institución.");
                        c.Item().Text("Dicha autorización se concede de manera gratuita, sin limitación territorial ni temporal, y comprende su difusión en medios digitales, electrónicos y redes sociales oficiales de UPASER, así como en cualquier otra plataforma en línea utilizada por la institución.");

                        c.Item().PaddingTop(40).Row(row => {
                            row.RelativeItem().AlignCenter().Column(col => { col.Item().BorderBottom(1).Width(60, QuestPDF.Infrastructure.Unit.Millimetre).Text(""); col.Item().Text("Firma del Padre o Tutor"); });
                            row.RelativeItem().AlignCenter().Column(col => { col.Item().BorderBottom(1).Width(60, QuestPDF.Infrastructure.Unit.Millimetre).Text(""); col.Item().Text("Firma del Alumno"); });
                        });
                    });
                });
            }

            if (imprimirTerminos)
            {
                container.Page(page =>
                {
                    page.Size(QuestPDF.Helpers.PageSizes.Letter);
                    page.Margin(2, QuestPDF.Infrastructure.Unit.Centimetre);
                    page.PageColor(QuestPDF.Helpers.Colors.White);
                    page.DefaultTextStyle(x => x.FontSize(10).FontFamily("Arial"));

                    page.Content().Column(c => {
                        c.Item().Text("TÉRMINOS Y CONDICIONES").Bold().FontSize(14).AlignCenter();
                        c.Item().PaddingTop(15);

                        c.Item().Text("Es de suma importancia leer cuidadosamente este apartado antes de iniciar tu curso, para que conozcas tus derechos y obligaciones como alumno UPASER.").Bold();
                        c.Item().PaddingTop(5).Text("La Unidad Profesional de Asesoría y Regularización (UPASER) tiene como garantía que el alumno se quede en sus primeras 5 opciones que seleccione en el concurso ECOEMS/103 Municipios/EXAMEN DE INGRESO A UNIVERSIDAD (UNAM, IPN, UAM, UAEMex, ETC), asegurando que nuestro curso es competente bajo nuestro método de enseñanza.");
                        c.Item().PaddingTop(5).Text("Antes de efectuar el pago, el usuario deberá aceptar la Política de Privacidad, una vez confirmado el pago del curso seleccionado por el aspirante este no podrá solicitar reembolso.");
                        
                        c.Item().PaddingTop(10).Text(t => { 
                            t.Span("I. Clases:").Bold(); 
                            t.Span(" Están sujetas a modificaciones, UPASER se reserva el derecho de cancelar o cambiar cualquier clase, se les notificara a los alumnos o participantes cualquier cambio a través de los grupos de WhatsApp oficiales. UPASER esta obligado a reponer la clase cancelada, si este fuera el caso."); 
                        });
                        
                        c.Item().PaddingTop(5).Text(t => { 
                            t.Span("II. Comportamiento:").Bold(); 
                            t.Span(" UPASER se reserva el derecho de retirar a cualquier persona registrada en el curso, cuyo comportamiento sea considerado inapropiado, por parte de UPASER o sus docentes. En estas circunstancias UPASER no reembolsara ninguna tarifa."); 
                        });
                        
                        c.Item().PaddingTop(5).Text(t => { 
                            t.Span("III. Plazo para registrarse:").Bold(); 
                            t.Span(" Estamos contentos de apoyar a nuestros alumnos con el proceso de registro en las plataformas oficiales ECOEMS/103 MUNICIPIOS, sin embargo, es responsabilidad total del aspirante. En caso de que el aspirante no se registre en las fechas que la convocatoria este abierta no habrá ningún tipo de reembolso por el pago efectuado al curso de capacitación."); 
                        });
                        
                        c.Item().PaddingTop(5).Text(t => { 
                            t.Span("IV. Talleres opcionales:").Bold(); 
                            t.Span(" UPASER programara talleres a lo largo del curso de capacitación, estos talleres son considerados un plus CON COSTO para cualquier alumno UPASER."); 
                        });

                        c.Item().PaddingTop(40).Row(row => {
                            row.RelativeItem().AlignCenter().Column(col => { col.Item().BorderBottom(1).Width(60, QuestPDF.Infrastructure.Unit.Millimetre).Text(""); col.Item().Text("Firma del Padre o Tutor"); });
                            row.RelativeItem().AlignCenter().Column(col => { col.Item().BorderBottom(1).Width(60, QuestPDF.Infrastructure.Unit.Millimetre).Text(""); col.Item().Text("Firma del Alumno"); });
                        });
                    });
                });
            }
        }).GeneratePdf();
    }

    private async Task DescargarPdf(byte[] bytes, string fileName)
    {
        var base64 = Convert.ToBase64String(bytes);
        var js = $"var a = document.createElement('a'); a.href = 'data:application/pdf;base64,{base64}'; a.download = '{fileName}'; document.body.appendChild(a); a.click(); document.body.removeChild(a);";
        await JSRuntime.InvokeVoidAsync("eval", js);
    }
}
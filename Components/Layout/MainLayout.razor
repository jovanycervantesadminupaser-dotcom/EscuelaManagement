@inherits LayoutComponentBase
@using MudBlazor
@using EscuelaManagement.Data.Models
@using EscuelaManagement.Data.Services
@inject NavigationManager Navigation
@inject FirebaseService Firebase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">@nombreEscuela</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Logout" OnClick="CerrarSesion">
            Cerrar Sesión
        </MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-4">
            @* EL TRUCO: @key obliga a Blazor a reiniciar el div y la animación al cambiar de URL *@
            <div @key="Navigation.Uri" class="@claseAnimacion">
                @Body
            </div>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string nombreEscuela = "Cargando...";
    private string claseAnimacion = "fade-in-up"; // Estado inicial

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var configuracion = await Firebase.GetConfiguracionAsync();
            nombreEscuela = !string.IsNullOrEmpty(configuracion.NombreEscuela) ? configuracion.NombreEscuela : "EscuelaManager";
        }
        catch
        {
            nombreEscuela = "EscuelaManager";
        }
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task CerrarSesion()
    {
        // 1. Aplicar animación de salida
        claseAnimacion = "fade-out-down";
        StateHasChanged(); 

        // 2. Esperar a que termine la animación (400ms)
        await Task.Delay(400);

        // 3. Redirigir al inicio/login
        Navigation.NavigateTo("/");
        
        // Restaurar para futuras navegaciones
        claseAnimacion = "fade-in-up"; 
    }
}